# FeedOracle Stablecoin Risk MCP Server
# Copy to .env and configure

# Server port (default: 5252)
PORT=5252

# Etherscan V2 API key (free tier works, get at https://etherscan.io/myapikey)
ETHERSCAN_KEY=your_etherscan_key_here

# Internal FeedOracle APIs (optional, falls back gracefully)
FEED_API=http://127.0.0.1:5080
PEG_API=http://127.0.0.1:5215
